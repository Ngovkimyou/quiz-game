{
	"name": "quiz-game",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''; lefthook install; pnpm run hooks:install",
		"hooks:install": "node -e \"const { existsSync } = require('node:fs'); if (!existsSync('scripts/configure-git-hooks.mjs')) process.exit(0); import('./scripts/configure-git-hooks.mjs').catch((error) => { console.error(error); process.exit(1); });\"",
		"check:ci": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --write . && prettier --check . && eslint .",
		"lint:eslint": "eslint . --cache --cache-strategy content",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run",
		"test:coverage": "vitest run --coverage",
		"gen": "wrangler types",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"spellcheck": "cspell \"**/*.{js,ts,jsx,tsx,md,json}\" --no-progress",
		"spellcheck:strict": "cspell \"**/*.{js,ts,jsx,tsx,md,json}\" --no-progress --fail-fast",
		"update:latest": "pnpm update --latest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/nanoid": "^3.0.0",
		"@types/node": "^25.5.0",
		"@types/papaparse": "^5.5.2",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"cspell": "^9.7.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-no-commented-code": "^1.0.10",
		"eslint-plugin-svelte": "^3.15.2",
		"eslint-plugin-unicorn": "^63.0.0",
		"globals": "^17.4.0",
		"lefthook": "^2.1.4",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"svelte-fast-check": "^0.4.5",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.74.0"
	},
	"dependencies": {
		"@google/genai": "^1.45.0",
		"@libsql/client": "^0.17.0",
		"flexsearch": "^0.8.212",
		"nanoid": "^5.1.7",
		"papaparse": "^5.5.3",
		"socket.io": "^4.8.3"
	},
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.0",
			"undici": "^7.24.0"
		}
	}
}
